{
  "name": "nano-banana-app",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client && npm install --prefix bot",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev:bot": "npm run dev --prefix bot",
    "dev": "concurrently -n server,client,bot -c blue,green,magenta \"npm:dev:server\" \"npm:dev:client\" \"npm:dev:bot\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
